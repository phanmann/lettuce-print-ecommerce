# Lettuce Print E-commerce Configuration

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://lettuceprint.com
NEXT_PUBLIC_API_URL=https://lettuceprint.com/api

# Stripe Configuration (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Email Configuration (for order confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Database Configuration (for production)
DATABASE_URL=postgresql://username:password@localhost:5432/lettuce_print

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,ai,psd,eps

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-here
ENCRYPTION_KEY=your-32-character-encryption-key

# External Services
PRICING_CALCULATOR_URL=https://phanmann.github.io/lettuce-print-calculator/

# Development Configuration
NODE_ENV=development
DEBUG=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Order Configuration
MIN_ORDER_AMOUNT=15.00
MAX_ORDER_AMOUNT=10000.00
TAX_RATE=0.08
SHIPPING_COST=15.00

# Business Information
BUSINESS_NAME=Lettuce Print
BUSINESS_EMAIL=info@lettuceprint.com
BUSINESS_PHONE=(555) 123-4567
BUSINESS_ADDRESS=123 Print Street, Brooklyn, NY 11201
{
  "name": "lettuce-print",
  "version": "1.0.0",
  "description": "Brooklyn's premier printing service - Professional B2B printing with local expertise",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next node_modules",
    "install:clean": "npm run clean && npm install",
    "build:analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "nodemailer": "^8.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.51.0",
    "eslint-config-next": "14.0.0",
    "postcss": "^8.4.31",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "printing",
    "brooklyn",
    "b2b",
    "business cards",
    "flyers",
    "banners",
    "nextjs",
    "typescript",
    "tailwindcss"
  ],
  "author": "Lettuce Print Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lettuceprint/lettuce-print.git"
  },
  "bugs": {
    "url": "https://github.com/lettuceprint/lettuce-print/issues"
  },
  "homepage": "https://lettuceprint.com"
}
